// routing-model v2 data (see docs/routing-model.md). Built in parallel with routes.hu;
// components are ported here and proven equivalent by test/test_v2_equivalence.py.
{
    // OS layer: lineage (`using`) + which package manager is `native` + version scales.
    // `provides:` lists capabilities baseline in that environment (satisfied for free).
    os: {
        linux:   { }
        debian:  { using: linux    native: apt      scale-root: true }
        ubuntu:  { using: debian    scale-root: true }
        pop_os!: { using: ubuntu }
        fedora:  { using: linux     native: dnf      scale-root: true }
        rhel:    { using: fedora }
        arch:    { using: linux     native: pacman }
    }

    // Mechanism config: dependencies inherent to a mechanism (the old family !depends).
    mechanisms: {
        flatpak:     { requires: flatpak }
        appImage:    { requires: libfuse2 }
        cargo:       { requires: cargo }              // a crate needs the cargo tool
        debian-font: { requires: [ fontconfig, unzip ] }
        pip:         { requires: python3-pip }        // `pip install --user` needs pip
    }

    // Component layer: each is a capability + a list of context-selected bindings.
    components: {
        // --- trivial natives ---
        flatpak:    { install: [ { via: native } ] }
        fontconfig: { install: [ { via: native } ] }
        unzip:      { install: [ { via: native } ] }
        ripgrep:    { install: [ { via: native } ] }
        python3-pip: { install: [ { via: native  name: { pacman: python-pip } } ] }

        // btop lives in EPEL on EL (needs epel enabled), base repos everywhere else.
        // Two native bindings: the EL one adds `requires: epel`; both are dnf\btop.
        btop: {
            install: [
                { via: native  when: "rhel"  requires: epel }
                { via: native }
            ]
        }

        // EPEL: a capability enabled by installing epel-release (only on EL). Anything
        // that `requires: epel` is a no-op off EL (nothing needs it) and pulls this in on EL.
        epel-release: {
            provides: epel
            install: [ { via: native  when: "rhel" } ]
        }

        // pipx: the version-variant collapse. Native package where the repos have it;
        // a pip --user bootstrap on old Ubuntu/Debian; +EPEL on EL. Was a \pip family +
        // apt/dnf/pacman entries + two @version blocks + a rhel override — now three bindings.
        pipx: {
            install: [
                { via: pip     when: "(ubuntu < 23.04) or (debian < 12)"  name: pipx }
                { via: native  when: "rhel"  requires: epel  name: { pacman: python-pipx } }
                { via: native  name: { pacman: python-pipx } }
            ]
        }

        // native, name differs by manager
        libfuse2: {
            install: [ { via: native  name: { dnf: fuse-libs  pacman: fuse2  default: libfuse2 } } ]
        }
        cargo: {
            install: [ { via: native  name: { pacman: rust } } ]   // the cargo tool ships in `rust` on Arch
        }

        // --- non-native mechanisms with mechanism-level deps ---
        chrome: {
            install: [ { via: flatpak  app: com.google.Chrome } ]  // -> requires flatpak
        }
        tree-sitter-cli: {
            install: [ { via: cargo  name: tree-sitter-cli } ]     // -> requires cargo (the tool)
        }
        mononoki-nerd: {
            install: [ { via: debian-font  name: Mononoki          // -> requires fontconfig + unzip
                         version: { github: ryanoasis/nerd-fonts  asset: "Mononoki.zip" } } ]
        }

        // when:-varying: native on Pop (the NVIDIA rig), flatpak elsewhere
        steam: {
            install: [
                { via: native   when: "pop_os!"  name: "steam:i386"  foreign-arch: i386 }
                { via: flatpak  app: com.valvesoftware.Steam }
            ]
        }

        // --- dotfiles ---
        bashDotD: {
            install: [ { via: dotfiles  aliases: { src: bash_aliases  dst: ~/.bash_aliases } } ]
        }

        // --- appImage apps (fetch-artifact) + method-independent dotfiles chain ---
        neovim: {
            requires: [ ripgrep, tree-sitter-cli ]                  // method-independent
            dotfiles: {
                requires: bashDotD
                config:  { src: neovim         dst: $XDG_CONFIG_HOME/nvim }
                aliases: { src: bash.d/neovim.sh  dst: ~/.bash.d/neovim.sh }
            }
            install: [ { via: appImage  name: Neovim               // -> requires libfuse2
                         version: { github: neovim/neovim  asset: "nvim-linux-$ARCH.appimage" }
                         url: "https://github.com/neovim/neovim/releases/download/$VERSION/nvim-linux-$ARCH.appimage"
                         path: ~/apps/nvim.appimage } ]
        }
        arduino: {
            dotfiles: { requires: bashDotD  src: bash.d/arduino.sh  dst: ~/.bash.d/arduino.sh }
            install: [ { via: appImage  name: "Arduino IDE"
                         version: { github: arduino/arduino-ide  asset: "arduino-ide_*_Linux_64bit.AppImage" }
                         url: "https://github.com/arduino/arduino-ide/releases/download/$VERSION/arduino-ide_$VERSION_Linux_64bit.AppImage"
                         path: ~/apps/arduino-ide.appimage } ]
        }

        // --- parts: composition (a component that IS several others, no unit of its own) ---
        libvulkan1:            { install: [ { via: native } ] }
        vulkan-loader:         { install: [ { via: native } ] }
        vulkan-icd-loader:     { install: [ { via: native } ] }
        vulkan-radeon:         { install: [ { via: native } ] }
        vulkan-intel:          { install: [ { via: native } ] }
        vulkan-swrast:         { install: [ { via: native } ] }
        mesa-vulkan-drivers:   { install: [ { via: native } ] }
        vulkan-runtime: {
            install: [
                { via: parts  when: "debian"  parts: [ libvulkan1, mesa-vulkan-drivers ] }
                { via: parts  when: "fedora"  parts: [ vulkan-loader, mesa-vulkan-drivers ] }  // fedora + EL
                { via: parts  when: "arch"    parts: [ vulkan-icd-loader, vulkan-radeon, vulkan-intel, vulkan-swrast ] }
            ]
        }

        // --- github .deb where no repo has it, native package elsewhere (cpu-keyed asset) ---
        fastfetch: {
            install: [
                { via: native  when: "debian"  deb-source: "github:fastfetch-cli/fastfetch"
                  asset: { x86_64: fastfetch-linux-amd64.deb  aarch64: fastfetch-linux-aarch64.deb } }
                { via: native }
            ]
        }
    }
}
