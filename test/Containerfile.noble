# Disposable ubuntu:24.04 (noble) sandbox — the MODERN path: apt ships `pipx`, and
# PEP 668 marks the system env externally-managed (so configsys must NOT use pip
# --user here; apod resolves pipx -> apt\pipx). Mirrors Containerfile otherwise.
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3 python3-venv python3-pip python3-dev gcc sudo ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash tester \
    && echo 'tester ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/tester \
    && chmod 0440 /etc/sudoers.d/tester

COPY --chown=tester:tester . /home/tester/configsys

USER tester
WORKDIR /home/tester/configsys

CMD ["bash", "test/integration_apod.sh"]
