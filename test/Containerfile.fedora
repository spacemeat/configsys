# Disposable fedora:41 (dnf5) sandbox for configsys dnf integration tests. Nothing
# touches the host: all installs/removes happen in the container, discarded on exit.
# python3-devel + gcc are present so `pip install humon` can build the extension.
FROM fedora:41

RUN dnf install -y --setopt=install_weak_deps=False \
        python3 python3-pip python3-devel gcc sudo ca-certificates \
    && dnf clean all

# Non-root user with passwordless sudo — configsys shells out to `sudo dnf`.
RUN useradd -m -s /bin/bash tester \
    && echo 'tester ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/tester \
    && chmod 0440 /etc/sudoers.d/tester

COPY --chown=tester:tester . /home/tester/configsys

USER tester
WORKDIR /home/tester/configsys

CMD ["bash", "test/integration_dnf.sh"]
