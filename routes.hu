// routes.hu — the capability/component routing data (see docs/routing-model.md and the
// routing section of CLAUDE.md). Loaded by configsys/routes.py; resolution in resolve.py.
{
    // OS layer: lineage (`using`) + which package manager is `native` + version scales.
    // `provides:` lists capabilities baseline in that environment (satisfied for free).
    os: {
        linux:   { }

        // The C library is an axis orthogonal to distro family: mainstream distros are glibc,
        // Alpine (and musl-Void) are musl. Prebuilt glibc binaries (most AppImages, many
        // tarballs) can't run under musl's loader. `glibc_linux` carries a `glibc` capability
        // that the glibc families inherit; drivers/bindings that fetch glibc artifacts
        // `requires: glibc`, so they cleanly decline on Alpine instead of installing a corpse.
        glibc_linux: { using: linux  provides: glibc }

        // Debian family (apt). A scale-root owns a version numbering. Pop shares Ubuntu's exact
        // numbers (Pop 22.04 IS Ubuntu 22.04), so it borrows Ubuntu's scale — no scale-root.
        // Mint and LMDE use their OWN numbers (Mint 21 = Ubuntu 22.04, different digits), so
        // each is its own scale-root — a versioned `ubuntu`/`debian` atom must NOT misfire on
        // them. Bare `ubuntu`/`debian` still match all of them (route inheritance by identity).
        debian:    { using: glibc_linux  native: apt   scale-root: true }
        ubuntu:    { using: debian    scale-root: true }
        pop_os!:   { using: ubuntu }
        linuxmint: { using: ubuntu    scale-root: true }            // Mint main (own numbering)
        lmde:      { using: debian    scale-root: true }            // Mint Debian Edition (own numbering)

        // RHEL family (dnf). The EL rebuilds share rhel's routes + version line; distinct
        // blocks (vs. one aliased `rhel`) buy them identity — `when: "rocky"`, correct display.
        redhat:    { using: glibc_linux  native: dnf }              // fedora + EL share dnf
        fedora:    { using: redhat    scale-root: true }            // fedora proper (YY release)
        rhel:      { using: redhat    scale-root: true }            // EL scale-root (N release)
        rocky:     { using: rhel }
        almalinux: { using: rhel }
        centos:    { using: rhel }                                  // CentOS Stream

        // Arch family (pacman). Rolling — no version scale; membership is by identity only.
        arch:        { using: glibc_linux  native: pacman }
        manjaro:     { using: arch }
        endeavouros: { using: arch }

        // Alpine (apk). musl, NOT glibc — so it hangs off `linux`, not `glibc_linux`. glibc-only
        // fetch-a-binary bindings decline here (unroutable = a clean diagnostic); the optional
        // `gcompat` shim can re-enable them per-machine (see the gcompat component).
        alpine: { using: linux  native: apk }

        // openSUSE / SUSE (zypper). glibc. One synthetic parent declares the driver; Leap is a
        // scale-root (versioned, 15.x) while Tumbleweed is rolling (bare membership, like arch)
        // — a clean demo of identity-vs-scale being orthogonal. Block names use `_` (the `when:`
        // DSL has no `-`); os-release's `opensuse-leap`/`-tumbleweed` alias in.
        opensuse:             { using: glibc_linux  native: zypper }
        opensuse_leap:        { using: opensuse  scale-root: true }
        opensuse_tumbleweed:  { using: opensuse }
    }

    // Driver config: dependencies inherent to a driver (its prerequisite tooling).
    drivers: {
        flatpak:     { requires: flatpak }
        appImage:    { requires: [ libfuse2, glibc ] }   // AppImages are glibc-built: decline on musl
        cargo:       { requires: cargo }              // a crate needs the cargo tool
        font: { requires: [ fontconfig, unzip ] }
        // pip / pipx on musl (Alpine): pip prefers a `musllinux` wheel and pure-Python wheels
        // install fine, but a C-extension package that ships ONLY `manylinux` (glibc) wheels
        // falls back to building from its sdist — which needs a toolchain (gcc, musl-dev,
        // python3-dev) + the package's own C headers. configsys does NOT model those build deps
        // (they're per-package and usually unneeded), so such a build surfaces pip's own
        // compiler error; add the toolchain to a profile if you hit it. No base pip/pipx
        // component is affected — this only concerns C-extension tools a user adds on Alpine.
        pip:         { requires: python3-pip }        // `pip install --user` needs pip
        pipx:        { requires: pipx }               // a PyPI CLI needs the pipx tool
        tarball:     { requires: curl }               // fetch the archive with curl
        aur:         { requires: [ base-devel, git ] } // makepkg -si builds from PKGBUILD
    }

    // Component layer: each is a capability + a list of context-selected bindings.
    components: {
        // --- trivial natives ---
        flatpak:    { install: [ { via: native } ] }
        fontconfig: { install: [ { via: native } ] }
        unzip:      { install: [ { via: native } ] }
        firefox:    { install: [ { via: native  repo-component: universe } ] }   // in base repos everywhere (incl. EL); apt: universe
        doas:       { install: [ { via: apk  when: "alpine" } ] }                 // Alpine's sudo (apk-only; folded from the alpine plugin)

        // gcompat: Alpine's glibc-compat shim. It `provides: glibc`, so it can re-enable the
        // glibc-only bindings (AppImages, glibc tarballs) that otherwise decline on musl. It is
        // marked `opt-in` — NEVER auto-pulled to satisfy a `requires: glibc`, because the shim
        // is BEST-EFFORT: it maps many glibc binaries onto musl but not all (symbol-version
        // gaps, NSS, TLS quirks). Silently installing it, then maybe still failing to run the
        // binary, is exactly the surprise configsys avoids. So a musl box declines glibc
        // binaries by default; to gamble on the shim, opt in per-machine — either add `gcompat`
        // to a profile, or provider-pin it:  pins: { glibc: gcompat }.
        gcompat: {
            provides: glibc
            opt-in: true
            install: [ { via: apk  when: "alpine" } ]
        }
        python3-pip: { install: [ { via: native  name: { pacman: python-pip } } ] }
        // EL keeps these in EPEL, base repos everywhere else — same two-binding shape as btop.
        // `repo-component: universe` is the apt archive area (read only by apt; ignored on dnf/pacman).
        ripgrep: { install: [ { via: native  when: "rhel"  requires: epel } { via: native  repo-component: universe } ] }
        fzf:     { install: [ { via: native  when: "rhel"  requires: epel } { via: native  repo-component: universe } ] }
        xclip:   { suggests: xclip-dotfiles
                   install: [ { via: native  when: "rhel"  requires: epel } { via: native  repo-component: universe } ] }
        xclip-dotfiles: { install: [ { via: dotfiles  requires: bash-dotfiles  src: bash.d/xclip.sh  dst: ~/.bash.d/xclip.sh } ] }

        // btop lives in EPEL on EL (needs epel enabled), base repos everywhere else.
        // Two native bindings: the EL one adds `requires: epel`; both are dnf\btop.
        btop: {
            install: [
                { via: native  when: "rhel"  requires: epel }
                { via: native  repo-component: universe }
            ]
        }

        configsys-dotfiles: {
            install: [
                { via: dotfiles  requires: bash-dotfiles  src: bash.d/configsys.sh  dst: ~/.bash.d/configsys.sh }
            ]
        }

        // EPEL: a capability enabled by installing epel-release (only on EL). Anything
        // that `requires: epel` is a no-op off EL (nothing needs it) and pulls this in on EL.
        epel-release: {
            provides: epel
            install: [ { via: native  when: "rhel" } ]
        }

        // pipx: the version-variant collapse. Native package where the repos have it;
        // a pip --user bootstrap on old Ubuntu/Debian; +EPEL on EL. Was a \pip family +
        // apt/dnf/pacman entries + two @version blocks + a rhel override — now three bindings.
        pipx: {
            install: [
                { via: pip     when: "(ubuntu < 23.04) or (debian < 12)"  name: pipx  version: { pypi: pipx } }
                { via: native  when: "rhel"  requires: epel  name: { pacman: python-pipx } }
                { via: native  name: { pacman: python-pipx } }
            ]
        }

        // native, name differs by manager
        libfuse2: {
            install: [ { via: native  repo-component: universe  name: { dnf: fuse-libs  pacman: fuse2  apk: fuse  default: libfuse2 } } ]
        }
        cargo: {
            install: [ { via: native  repo-component: universe  name: { pacman: rust } } ]   // the cargo tool ships in `rust` on Arch
        }

        // --- non-native drivers with driver-level deps ---
        chrome: {
            install: [ { via: flatpak  hub: flathub  app: com.google.Chrome } ]
        }
        tree-sitter-cli: {
            install: [ { via: cargo  name: tree-sitter-cli  version: { crates: tree-sitter-cli } } ]
        }
        mononoki-nerd: {
            install: [ { via: font  name: Mononoki          // -> requires fontconfig + unzip
                         version: { github: ryanoasis/nerd-fonts  asset: "Mononoki.zip" }
                         url: "https://github.com/ryanoasis/nerd-fonts/releases/download/$VERSION/Mononoki.zip" } ]
        }

        // when:-varying: native on Pop (the NVIDIA rig), flatpak elsewhere
        steam: {
            install: [
                { via: native   when: "pop_os!"  name: "steam:i386"  foreign-arch: i386 }
                { via: flatpak  hub: flathub  app: com.valvesoftware.Steam }
            ]
        }

        // --- apps: native everywhere. A clean-config tool manages its ~/.config as a
        // dir-dotfile (content in dotfiles/<name>/ symlinked to $XDG_CONFIG_HOME/<name>, like
        // neovim). The dotfiles are `suggests:` (soft) so the app installs before dotfiles/<name>/
        // has your content. Apps with a FAT ~/.config (profile + cache/state) only `suggests:`
        // their dotfiles for now — pending a dir-vs-specific-files call.
        htop: {
            suggests: htop-dotfiles
            install: [
                { via: native  when: "rhel"  requires: epel }   // EL ships htop in EPEL, like btop
                { via: native  repo-component: universe }
            ]
        }
        htop-dotfiles: {
            install: [ { via: dotfiles  config: { src: htop  dst: $XDG_CONFIG_HOME/htop } } ]
        }

        podman: {
            suggests: podman-dotfiles
            install: [ { via: native  repo-component: universe } ]   // apt universe / dnf (EL AppStream) / pacman
        }
        podman-dotfiles: {   // ~/.config/containers — shared by podman / buildah / skopeo
            install: [ { via: dotfiles  config: { src: containers  dst: $XDG_CONFIG_HOME/containers } } ]
        }

        libreoffice: {   // fat ~/.config/libreoffice (profile + cache) — dotfiles pending
            suggests: libreoffice-dotfiles
            install: [ { via: native  repo-component: universe  name: { pacman: libreoffice-fresh } } ]
        }

        // kicad: native where it's packaged, Flathub (org.kicad.KiCad) where it isn't. It's in
        // NO EL9 repo (base/EPEL/CRB/RPM Fusion, verified on rockylinux:9), so native is guarded
        // `not rhel` and the flatpak binding catches EL (and is a per-machine `pin` away anywhere
        // the distro package is too old). A from-source build is the configsys-kicad plugin's
        // `kicad-build` override, the way blender-build overrides native blender.
        kicad: {   // fat-ish config — dotfiles pending
            suggests: kicad-dotfiles
            install: [ { via: native   when: "not rhel"  repo-component: universe }
                       { via: flatpak  hub: flathub  app: org.kicad.KiCad } ]
        }

        // blender: the easy default is the native package (the editor). A from-source build
        // (to get a `bpy` module matching your editor) is a personal override that lives in a
        // user layer, the way a Pop-only native Steam does. Fat versioned config
        // (~/.config/blender/<ver>) — dotfiles deferred. On EL it's in EPEL; base repos elsewhere.
        blender: {
            suggests: blender-dotfiles
            install: [ { via: native  when: "rhel"  requires: epel }
                       { via: native  repo-component: universe } ]
        }

        // GPU compute toolchains (promoted from the configsys-blender plugin). General-purpose —
        // cuda-toolkit is used well beyond Blender — but named here so a source-build Blender's
        // per-backend `requires:` (cuda-toolkit / rocm-hip / intel-oneapi-basekit) resolves in
        // base. Package names are the baseline distro-repo ones: real GPU work usually wants the
        // vendor repos (NVIDIA cuda, AMD ROCm, Intel oneAPI), which are their own setup.
        cuda-toolkit: {
            install: [ { via: native  name: { apt: nvidia-cuda-toolkit  dnf: cuda  pacman: cuda } } ]
        }
        rocm-hip: {
            install: [ { via: native  name: { apt: rocm-hip-sdk  dnf: rocm-hip  pacman: rocm-hip-sdk } } ]
        }
        intel-oneapi-basekit: {
            install: [ { via: native  name: { apt: intel-basekit  dnf: intel-basekit  pacman: intel-oneapi-basekit } } ]
        }

        // docker: "the engine, working" = the package + its daemon enabled. Post-install is just
        // composition — docker-service is an ordinary component ordered after docker-engine via
        // `requires:` (which also avoids the package<->service dependency cycle a single unit
        // would create). Passwordless docker (group membership) is a security opt-in: add
        // `docker-group` to your profile alongside `docker`. RHEL steers you to podman — use that
        // there. Config lives in ~/.docker, so no dotfiles.
        docker: {
            install: [ { via: parts  parts: [ docker-engine, docker-service ] } ]
        }
        docker-engine: {
            install: [ { via: native  repo-component: universe  name: { dnf: moby-engine  pacman: docker  default: docker.io } } ]
        }
        docker-service: {
            requires: docker-engine
            install: [ { via: service  unit: docker } ]
        }
        docker-group: {   // opt-in: passwordless docker (usermod -aG docker $YOU). Needs the group the engine creates.
            requires: docker-engine
            install: [ { via: group  name: docker } ]
        }

        // discord / slack: flatpak everywhere (no uniform native path — Fedora has none), and
        // their config is sandboxed under ~/.var/app and holds auth tokens, so no dotfiles.
        discord: { install: [ { via: flatpak  hub: flathub  app: com.discordapp.Discord } ] }
        slack:   { install: [ { via: flatpak  hub: flathub  app: com.slack.Slack } ] }

        // --- media & creative apps -------------------------------------------------
        // Flatpak-preferred: the Flathub builds are current and not hobbled by the sandbox for
        // these. gimp/krita also take a native binding on Alpine — musl, where a native apk
        // package beats pulling a glibc flatpak runtime (and both are in Alpine's community
        // repo). Elsewhere, and for the others, a native default is a per-machine `pin` away.
        gimp: {
            install: [ { via: native   when: "alpine" }
                       { via: flatpak  hub: flathub  app: org.gimp.GIMP } ]
        }
        krita: {
            install: [ { via: native   when: "alpine" }
                       { via: flatpak  hub: flathub  app: org.kde.krita } ]
        }
        ardour: { install: [ { via: flatpak  hub: flathub  app: org.ardour.Ardour } ] }
        lmms:   { install: [ { via: flatpak  hub: flathub  app: io.lmms.LMMS } ] }
        // tenacity: the telemetry-free Audacity fork. No reliable native package anywhere, so
        // flatpak-only (unroutable on Alpine -> surfaces as a diagnostic, never a crash).
        tenacity: { install: [ { via: flatpak  hub: flathub  app: org.tenacityaudio.Tenacity } ] }

        // gnuradio: an SDR *framework* (Python bindings, out-of-tree modules) — flatpak is
        // impractical, so native everywhere (package name `gnuradio`).
        gnuradio: { install: [ { via: native } ] }

        // ffmpeg: native, but neither Fedora nor EL ships it in base repos — the full build
        // lives in RPM Fusion on both (Fedora and EL alike). `when: "redhat"` covers both;
        // rpmfusion-free (below) does the per-distro repo setup. Everywhere else it's in base.
        ffmpeg: {
            install: [ { via: native  when: "redhat"  requires: rpmfusion }
                       { via: native } ]
        }
        // vlc: RPM Fusion on Fedora, but EL carries it in EPEL (not RPM Fusion) — so the two
        // rpm families take different capability edges. Base repos everywhere else.
        vlc: {
            install: [ { via: native  when: "fedora"  requires: rpmfusion }
                       { via: native  when: "rhel"    requires: epel }
                       { via: native } ]
        }
        // RPM Fusion Free: enabling it = (EL only) turn on EPEL + CRB, then drop the free
        // .repo (dnf expands $releasever/$basearch and auto-imports the per-release key on the
        // first -y install) and pull the release package that formalizes the config. Fedora and
        // EL differ only in the repo path + key + those EL prereqs, so it's two bindings.
        // Provides the `rpmfusion` capability ffmpeg (both families) and vlc (Fedora) pull in.
        // Validated end to end on fedora:41 and rockylinux:9 (ffmpeg deps resolve). NOTE: EL
        // support targets the free rebuilds (Rocky/Alma/CentOS, CRB via config-manager); RHEL
        // proper enables CodeReady via subscription-manager, which the user does once by hand.
        rpmfusion-free: {
            provides: rpmfusion
            install: [
                { via: native  when: "rhel"  requires: epel  name: rpmfusion-free-release
                  enable-repo: crb
                  repo-id: rpmfusion-free  repo-name: "RPM Fusion for EL - Free"
                  repo-url: "https://download1.rpmfusion.org/free/el/updates/$releasever/$basearch/"
                  pubkey-url: "https://rpmfusion.org/keys?action=AttachFile&do=get&target=RPM-GPG-KEY-rpmfusion-free-el-$releasever" }
                { via: native  when: "fedora"  name: rpmfusion-free-release
                  repo-id: rpmfusion-free  repo-name: "RPM Fusion Free"
                  repo-url: "https://download1.rpmfusion.org/free/fedora/releases/$releasever/Everything/$basearch/os/"
                  pubkey-url: "https://rpmfusion.org/keys?action=AttachFile&do=get&target=RPM-GPG-KEY-rpmfusion-free-fedora-$releasever" }
            ]
        }

        // unityhub: the Unity Hub AppImage. Unity Editor(s) are installed THROUGH the Hub at
        // runtime — there's no `unity3d` package to route. Config in ~/.config/UnityHub (deferred).
        unityhub: {
            suggests: unityhub-dotfiles
            install: [ { via: appImage  name: "Unity Hub"  version: { static: latest }
                         url: "https://public-cdn.cloud.unity3d.com/hub/prod/UnityHub.AppImage"
                         path: ~/apps/UnityHub.AppImage } ]
        }

        // android-studio: Google's official tarball, unpacked scope-honoring (~/android-studio
        // for user, /opt/android-studio for system). No clean version API, so the version is a
        // manual pin — bump it from developer.android.com/studio. Fat IDE config deferred.
        android-studio: {
            suggests: android-studio-dotfiles
            install: [ { via: tarball  version: { static: 2024.2.1.11 }  requires: glibc   // glibc-linked JVM/launchers
                         url: "https://redirector.gvt1.com/edgedl/android/studio/ide-zips/$VERSION/android-studio-$VERSION-linux.tar.gz" } ]
        }

        // lazygit: native on fedora/arch; elsewhere (debian/EL) a static Go binary from the
        // GitHub release, unpacked under ~/apps/lazygit (scope-honoring). Its bash.d snippet
        // aliases `lazygit` to that binary when present (a no-op where it's native on PATH).
        lazygit: {
            suggests: lazygit-dotfiles
            install: [
                { via: native  when: "fedora" }
                { via: native  when: "arch" }
                { via: tarball  installDir: apps/lazygit
                  version: { github: jesseduffield/lazygit  strip-v: true  asset: "lazygit_*_Linux_x86_64.tar.gz" } }
            ]
        }
        lazygit-dotfiles: {
            install: [ { via: dotfiles  requires: bash-dotfiles  src: bash.d/lazygit.sh  dst: ~/.bash.d/lazygit.sh } ]
        }

        // --- dotfiles ---
        bash-dotfiles: {
            // absorb-into: a pre-existing ~/.bash_aliases is MOVED into the ~/.bash.d loader
            // dir (and made executable) instead of just backed up, so the user's own aliases
            // keep running — the new ~/.bash_aliases sources every ~/.bash.d/*.sh.
            install: [ { via: dotfiles  aliases: { src: bash_aliases  dst: ~/.bash_aliases
                         absorb-into: ~/.bash.d/pre-configsys-aliases.sh } } ]
        }

        // --- appImage apps (fetch-artifact); config rides along as a required -dotfiles
        // component (a plain via:dotfiles component, so it can carry when: conditions too) ---
        neovim: {
            requires: [ ripgrep, tree-sitter-cli ]
            suggests: neovim-dotfiles
            install: [ { via: appImage  name: Neovim  scope: user   // -> requires libfuse2; keep it in ~/apps
                         version: { github: neovim/neovim  asset: "nvim-linux-$ARCH.appimage" }
                         url: "https://github.com/neovim/neovim/releases/download/$VERSION/nvim-linux-$ARCH.appimage"
                         path: ~/apps/nvim.appimage } ]
        }
        neovim-dotfiles: {
            install: [ { via: dotfiles  requires: bash-dotfiles
                         // If uncommented, this would clobber  your neovim config. I would never
                         // do that to you. The best move is to copy this *whole* neovim-dotfiles
                         // block to your own configsys.hu, and place it in components block. Then
                         // uncomment the line, and build your config in configsys/neovim.
                         // config:  { src: neovim         dst: $XDG_CONFIG_HOME/nvim }
                         aliases: { src: bash.d/neovim.sh  dst: ~/.bash.d/neovim.sh } } ]
        }
        arduino: {
            suggests: arduino-dotfiles
            install: [ { via: appImage  name: "Arduino IDE"
                         version: { github: arduino/arduino-ide  asset: "arduino-ide_*_Linux_64bit.AppImage" }
                         url: "https://github.com/arduino/arduino-ide/releases/download/$VERSION/arduino-ide_$VERSION_Linux_64bit.AppImage"
                         path: ~/apps/arduino-ide.appimage } ]
        }
        arduino-dotfiles: {
            install: [ { via: dotfiles  requires: bash-dotfiles  src: bash.d/arduino.sh  dst: ~/.bash.d/arduino.sh } ]
        }

        // --- parts: composition (a component that IS several others, no unit of its own) ---
        libvulkan1:            { install: [ { via: native } ] }
        vulkan-loader:         { install: [ { via: native } ] }
        vulkan-icd-loader:     { install: [ { via: native } ] }
        vulkan-radeon:         { install: [ { via: native } ] }
        vulkan-intel:          { install: [ { via: native } ] }
        vulkan-swrast:         { install: [ { via: native } ] }
        mesa-vulkan-drivers:   { install: [ { via: native } ] }
        vulkan-runtime: {
            install: [
                { via: parts  when: "debian"  parts: [ libvulkan1, mesa-vulkan-drivers ] }
                { via: parts  when: "redhat"  parts: [ vulkan-loader, mesa-vulkan-drivers ] }  // fedora + EL
                { via: parts  when: "arch"    parts: [ vulkan-icd-loader, vulkan-radeon, vulkan-intel, vulkan-swrast ] }
            ]
        }

        // --- tarball + composition: the vulkan SDK and the vulkan-dev bundle ---
        // vulkan-sdk is ONE component that is both a tarball unit AND an inline config
        // dotfile (dotfiles\vulkan-sdk), keyed by the component; the tarball driver
        // pulls curl. (Old: a [tarball\vulkan-sdk, dotfiles\vulkan-sdk] list bundle.)
        vulkan-sdk: {
            suggests: vulkan-sdk-dotfiles
            install: [ { via: tarball  version: { static: 1.4.350.1 }  installDir: vulkan  requires: glibc   // glibc-linked SDK
                         url: "https://sdk.lunarg.com/sdk/download/$VERSION/linux/vulkansdk-linux-$ARCH-$VERSION.tar.xz" } ]
        }
        vulkan-sdk-dotfiles: {
            install: [ { via: dotfiles  requires: bash-dotfiles
                         aliases: { src: bash.d/vulkan-sdk.sh  dst: ~/.bash.d/vulkan-sdk.sh } } ]
        }
        // vulkan-dev X libs, per OS: Debian ships three; Fedora's libxcb-devel bundles
        // xinput+xinerama (+ xcb-util-cursor-devel); Arch's libxcb does likewise (+ xcb-util-cursor).
        libxcb-xinput0:        { install: [ { via: native  repo-component: universe } ] }
        libxcb-xinerama0:      { install: [ { via: native  repo-component: universe } ] }
        libxcb-cursor-dev:     { install: [ { via: native  repo-component: universe } ] }
        libxcb-devel:          { install: [ { via: native } ] }   // fedora + EL
        xcb-util-cursor-devel: { install: [ { via: native } ] }   // fedora + EL
        libxcb:                { install: [ { via: native } ] }   // arch
        xcb-util-cursor:       { install: [ { via: native } ] }   // arch
        // vulkan-dev: a parts bundle composing the X libs, build tools, the SDK tarball,
        // and the vulkan runtime (itself a parts aggregator). One binding per OS family;
        // build-essential now expands to real gcc packages on Fedora/Arch (gcc blocker resolved).
        vulkan-dev: {
            install: [
                { via: parts  when: "debian"
                  parts: [ libxcb-xinput0, libxcb-xinerama0, libxcb-cursor-dev,
                           build-essential, vulkan-sdk, vulkan-runtime ] }
                { via: parts  when: "redhat"
                  parts: [ libxcb-devel, xcb-util-cursor-devel,
                           build-essential, vulkan-sdk, vulkan-runtime ] }
                { via: parts  when: "arch"
                  parts: [ libxcb, xcb-util-cursor,
                           build-essential, vulkan-sdk, vulkan-runtime ] }
            ]
        }

        // --- github .deb where no repo has it, native package elsewhere (cpu-keyed asset) ---
        fastfetch: {
            install: [
                { via: native  when: "debian"  deb-source: "github:fastfetch-cli/fastfetch"
                  asset: { x86_64: fastfetch-linux-amd64.deb  aarch64: fastfetch-linux-aarch64.deb } }
                { via: native  when: "rhel"  requires: epel }   // EL ships fastfetch in EPEL
                { via: native }
            ]
        }

        curl: { install: [ { via: native } ] }
        git:        { install: [ { via: native } ] }

        // --- toolchain support ---
        // one native meta-package on Debian; no single package on Fedora/Arch, so a
        // faithful parts bundle there (the compilers + make), matching the old routes.

        make:    { install: [ { via: native } ] }

        build-essential: {
            install: [
                { via: native  when: "debian" }
                { via: parts  when: "redhat"  parts: [ gcc, gcc-cpp, make ] }
                { via: parts  when: "arch"    parts: [ gcc, make ] }
            ]
        }

        // software-properties-common is a software package in Ubuntu and Debian that provides
        // the add-apt-repository script. It allows users to easily manage independent software
        // sources and PPAs (Personal Package Archives) without manually editing the
        // /etc/apt/sources.list file.
        software-properties-common: { install: [ { via: native when: debian } ] }

        // gdb: base-repo native everywhere (apt main / dnf base / pacman extra; EL base, no
        // EPEL), plus its shell-startup dotfile.
        gdb: {
            suggests: gdb-dotfiles
            install: [ { via: native } ]
        }
        gdb-dotfiles: {   // gdb reads ~/.gdbinit natively (no bash-dotfiles loader needed)
            install: [ { via: dotfiles  src: gdbinit  dst: ~/.gdbinit } ]
        }

        // vscode: native from Microsoft's vendor repos. Debian/Ubuntu/Pop use the MS apt
        // repo (key + an inline `deb` source-line -> package `code`); Fedora/EL use the MS
        // dnf repo (key + a .repo file); Arch builds `visual-studio-code-bin` from the AUR
        // (the OSS `code` in the Arch repos is a different, unbranded build).
        vscode: {
            install: [
                { via: native  when: "debian"  name: code
                  pubkey-url: "https://packages.microsoft.com/keys/microsoft.asc"
                  pubkey-path: /usr/share/keyrings/packages.microsoft.asc
                  source-line: "deb [arch=amd64,arm64,armhf signed-by=/usr/share/keyrings/packages.microsoft.asc] https://packages.microsoft.com/repos/code stable main"
                  source-path: /etc/apt/sources.list.d/vscode.list }
                { via: native  when: "redhat"  name: code
                  pubkey-url: "https://packages.microsoft.com/keys/microsoft.asc"
                  repo-id: code  repo-name: "Visual Studio Code"
                  repo-url: "https://packages.microsoft.com/yumrepos/vscode" }
                { via: aur  when: "arch"  name: visual-studio-code-bin }
            ]
        }

        // --- AUR: packages built from PKGBUILD via makepkg -si (Arch only). The `aur`
        // driver pulls base-devel + git (the build toolchain); yay is the AUR helper
        // itself, prebuilt (-bin). Guarded to arch — the driver has no meaning elsewhere.
        base-devel: { install: [ { via: native when: "arch" } ] }
        yay: {
            install: [ { via: aur  when: "arch"  name: yay-bin  version: { aur: yay-bin } } ]
        }

        // gcc means "the C compiler works here" — but that's a different artifact per OS,
        // and the two never coexist in one context, so ONE component with per-OS bindings
        // reproduces the old dotfiles\gcc (Debian) and dnf\gcc / pacman\gcc (RH/Arch):
        //   Debian — the base compiler already ships in build-essential; this is just the
        //            `update-alternatives --config gcc` selector alias (a dotfile).
        //   Fedora/Arch — build-essential is a parts bundle needing the actual gcc
        //            *package*, which this same component provides natively.
        // gcc-select: the `update-alternatives --config gcc` alias dotfile (Debian only) —
        // required by the versioned gcc-NN toolchains so `gcc` points at the chosen one.
        gcc-select: {
            install: [ { via: dotfiles  when: "debian"  requires: bash-dotfiles
                         src: bash.d/gcc.sh  dst: ~/.bash.d/gcc.sh } ]
        }
        // gcc: the actual C compiler *package* (a build-essential part on Fedora/Arch; on
        // Debian the base compiler ships in build-essential, so there's no Debian binding).
        gcc: {
            install: [
                { via: native  when: "redhat" }   // fedora + EL
                { via: native  when: "arch" }     // arch gcc bundles g++
            ]
        }
        gcc-cpp: { install: [ { via: native  name: { dnf: "gcc-c++" } } ] }   // Fedora g++ (has a `+`)

        // --- versioned gcc. Three drivers, selected by OS/version:
        //   debian -> `gcc` (apt PPA + update-alternatives; needs build-essential, s-p-c, the alias)
        //   fedora -> `gcc` (dnf compat packages gccNN; availability is per-release)
        //   EL     -> `gcc-toolset` (SCL under /opt/rh)
        gcc-13: {
            install: [
                { via: gcc  when: "debian"  packages: [ gcc-13, g++-13 ]  slaves: [ g++ ]  ppa: ubuntu-toolchain-r/test
                  requires: [ build-essential, software-properties-common ]  suggests: gcc-select }
                { via: gcc  when: "fedora = 41"  packages: [ gcc13, gcc13-c++ ] }
                { via: gcc-toolset  when: "rhel" }
            ]
        }
        gcc-14: {
            install: [
                { via: gcc  when: "debian"  packages: [ gcc-14, g++-14 ]  slaves: [ g++ ]  ppa: ubuntu-toolchain-r/test
                  requires: [ build-essential, software-properties-common ]  suggests: gcc-select }
                { via: gcc  when: "fedora = 42"  packages: [ gcc14, gcc14-c++ ] }
                { via: gcc-toolset  when: "rhel" }
            ]
        }
        gcc-15: {
            install: [
                { via: gcc  when: "debian"  packages: [ gcc-15, g++-15 ]  slaves: [ g++ ]  ppa: ubuntu-toolchain-r/test
                  requires: [ build-essential, software-properties-common ]  suggests: gcc-select }
                { via: gcc-toolset  when: "rhel" }
            ]
        }

        // --- versioned clang. `clang` driver = native PM + update-alternatives:
        //   debian -> apt.llvm.org + alternatives (needs build-essential, curl, the alias)
        //   fedora -> dnf compat clangNN (per-release; the system clang covers the newest)
        //   EL     -> dnf compat clangNN from EPEL (requires epel)
        clang-select: {             // the `update-alternatives --config clang` alias dotfile
            requires: bash-dotfiles
            install: [ { via: dotfiles  when: "debian"  src: bash.d/clang.sh  dst: ~/.bash.d/clang.sh } ]
        }
        clang-18: {
            install: [
                { via: clang  when: "debian"  packages: [ clang-18 ]
                  requires: [ build-essential, curl ]  suggests: clang-select }
                { via: clang  when: "fedora"  packages: [ clang18 ] }
            ]
        }
        clang-19: {
            install: [
                { via: clang  when: "debian"  packages: [ clang-19 ]
                  requires: [ build-essential, curl ]  suggests: clang-select }
                { via: clang  when: "fedora = 41"  packages: [ clang ] }      // system clang -> /usr/bin/clang-19
                { via: clang  when: "fedora = 42"  packages: [ clang19 ] }
                { via: clang  when: "rhel"  packages: [ clang19 ]  requires: epel }
            ]
        }
        clang-20: {
            install: [
                { via: clang  when: "debian"  packages: [ clang-20 ]
                  requires: [ build-essential, curl ]  suggests: clang-select }
                { via: clang  when: "fedora = 42"  packages: [ clang ] }      // system clang -> /usr/bin/clang-20
                { via: clang  when: "rhel"  packages: [ clang20 ]  requires: epel }
            ]
        }
    }
}
